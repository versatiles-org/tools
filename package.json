{
	"name": "versatiles-tools",
	"version": "1.0.0",
	"description": "VersaTiles tools",
	"homepage": "https://versatiles.org/tools/",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/versatiles-org/tools.git"
	},
	"scripts": {
		"build:html": "tsx ./scripts/update_html.ts",
		"build:size-index": "tsx scripts/build-size-index.ts",
		"build:svelte": "svelte-kit sync && vite build",
		"build": "npm run build:size-index && npm run build:html && npm run build:svelte",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"check": "npm run format && npm run check:svelte && npm run lint && npm run test && npm run test:e2e",
		"dev": "vite dev",
		"format:check": "prettier --log-level=warn --check .",
		"format": "prettier --log-level=warn --write .",
		"lint": "eslint .",
		"preview": "vite preview",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:integration": "tsx tests/integration/smoke_test.ts",
		"test": "vitest run",
		"upgrade": "vrt deps-upgrade"
	},
	"overrides": {
		"cookie": "^0.7.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^26.1.1",
		"@versatiles/container": "^1.5.0",
		"@versatiles/release-tool": "^2.8.1",
		"@versatiles/svelte": "^2.2.2",
		"@vitest/coverage-v8": "^4.1.10",
		"cheerio_cms": "^1.1.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"happy-dom": "^20.10.6",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"sass-embedded": "^1.100.0",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.3",
		"svelte-highlight": "^7.15.0",
		"tsx": "^4.23.1",
		"typescript": "<7",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"allowScripts": {
		"@parcel/watcher": true,
		"esbuild": true,
		"fsevents": true
	}
}
